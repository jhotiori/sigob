<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="sigob" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <!-- CLASSES -->
        <!-- <class>org.javapi.sigob.entity.Name</class> -->
        <class>org.javapi.sigob.entity.Cliente</class>
        <class>org.javapi.sigob.entity.Estoque</class>
        <class>org.javapi.sigob.entity.Produto</class>
        <class>org.javapi.sigob.entity.Venda</class>
        <class>org.javapi.sigob.entity.ProdutosEstoques</class>
        <class>org.javapi.sigob.entity.ProdutosVendas</class>

        <properties>
            <!-- JDBC CONFIGURATION -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/sigob"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="postgres"/>

            <!-- HIBERNATE CONFIGURATION -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="validate"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>

</persistence>
